{
  "BackendBaseUrl": "",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Hangfire": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithClientIp" ],
    "Properties": {
      "Application": "ExaminationSystemWebAPI"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.\\sqlexpress;Database=ExamSystemDB;Integrated Security=True;TrustServerCertificate=True"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "*" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ]
  },
  "Jwt": {
    "Key": "This is a sample secret key - please don't use in production environment.'",
    "Issuer": "https://localhost.com/",
    "Audience": "https://localhost.com/",
    "DurationInHours": 1,
    "RefreshTokenLifeInDays": 7
  },
  "OTPSecretKey": "This is a sample secret key - please don't use in production environment.'",
  "SMTPConfig": {
    "Host": "localhost",
    "Port": 25,
    "Username": "",
    "Password": "",
    "EnableSsl": false,
    "FromEmail": "noreply@examsystem.local",
    "FromName": "Exam System"
  },
  "RedisConfig": {
    "Host": "localhost",
    "Port": 6379,
    "User": "",
    "Password": "",
    "Ssl": false,
    "AbortOnConnectFail": false,
    "InstanceName": "ExaminationSystem:"
  },
  "Tenancy": {
    "UnknownDomainAction": "RejectRequest",
    "DefaultTenantId": 1,
    "ExcludedPaths": [ "/health", "/hangfire" ]
  },
  "SystemServiceOptions": {
    "UseMemoryCache": false,
    "WriteToSeq": true
  }
}
